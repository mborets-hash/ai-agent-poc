# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.1

# Portfolio Configuration
PORTFOLIO_FILE=data/sample_portfolio.json

# News Feed URLs (comma-separated)
# NEWS_FEEDS=https://feeds.finance.yahoo.com/rss/2.0/headline?s=^GSPC&region=US&lang=en-US,https://feeds.marketwatch.com/marketwatch/topstories/

# Watchlist symbols (comma-separated)
# WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,SPY,QQQ,BND

# Agent Configuration
MAX_AGENT_ITERATIONS=15
VERBOSE_AGENT=true
